# Copy to .env (or .env.local for dev) before running. Both are LAN-only secrets — never commit.

# ── Dev (Vite) ─────────────────────────────────────────────────
VITE_HA_URL=ws://homeassistant.local:8123/api/websocket
VITE_HA_TOKEN=eyJhbGciOiJI...your_long_lived_token...

# ── Deploy (docker-compose) ────────────────────────────────────
# Host port the container is exposed on.
DASHBOARD_PORT=8080

# Container timezone — keeps the clock in WeatherCard correct.
TZ=Africa/Johannesburg
